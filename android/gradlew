#!/usr/bin/env sh
set -eu

APP_HOME=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
GRADLE_VERSION="9.3.1"
DIST_NAME="gradle-${GRADLE_VERSION}-bin.zip"
DIST_URL="https://services.gradle.org/distributions/${DIST_NAME}"
CACHE_ROOT="${GRADLE_USER_HOME:-$HOME/.gradle}/wrapper/dists/gradle-${GRADLE_VERSION}-bin/text-bootstrap"
ZIP_PATH="$CACHE_ROOT/$DIST_NAME"
INSTALL_DIR="$CACHE_ROOT/gradle-${GRADLE_VERSION}"

mkdir -p "$CACHE_ROOT"

if [ ! -x "$INSTALL_DIR/bin/gradle" ]; then
    if [ ! -f "$ZIP_PATH" ]; then
        echo "Downloading ${DIST_URL}" >&2
        curl -fsSL "$DIST_URL" -o "$ZIP_PATH"
    fi
    rm -rf "$INSTALL_DIR"
    unzip -q -o "$ZIP_PATH" -d "$CACHE_ROOT"
fi

exec "$INSTALL_DIR/bin/gradle" -p "$APP_HOME" "$@"
